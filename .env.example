# ─── Sami / Salud Mental — Variables de entorno ─────────────────────────
# Copia este archivo como .env y completa los valores que apliquen.
# Las que dejes vacías toman el default que está entre paréntesis.

# ── Base de datos ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./mental_health.db

# ── Modo debug ─────────────────────────────────────────────────────────
DEBUG=False

# ── Modelo NLP (BETO) ──────────────────────────────────────────────────
# Se descarga la primera vez (~1.1 GB).
MODEL_NAME=Recognai/bert-base-spanish-wwm-cased-xnli
# -1 = CPU. Para GPU usar el índice (0, 1, ...).
DEVICE=-1

# ── Autenticación JWT ──────────────────────────────────────────────────
# CAMBIAR EN PRODUCCIÓN. Generar con: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please
# Vida del token en minutos (1440 = 24 h).
JWT_EXPIRE_MINUTES=1440

# ── Backups automáticos ────────────────────────────────────────────────
# Hora (0-23) en la que el scheduler corre el backup diario.
BACKUP_HORA_DIARIA=2
# Días de retención antes de eliminar backups viejos.
BACKUP_RETENCION_DIAS=14

# ── OAuth (opcional) ───────────────────────────────────────────────────
# Si no se configuran, los botones de Google / Microsoft devuelven 503.
# Google: crear OAuth Client en https://console.cloud.google.com (tipo Web)
#         y registrar http://localhost:5173/oauth-callback como redirect.
GOOGLE_CLIENT_ID=

# Microsoft: registrar app en https://entra.microsoft.com (App registrations),
#            tipo Personal Microsoft accounts only o Any + personal,
#            mismo redirect URI como SPA.
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT=common

# Redirect URI que recibe el callback OAuth en el frontend.
OAUTH_REDIRECT_URI=http://localhost:5173/oauth-callback

# ── Seed inicial de admin ──────────────────────────────────────────────
# Lo usa `python -m scripts.seed_admin` para crear el primer usuario.
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=Admin12345
ADMIN_NOMBRE=Admin
ADMIN_APELLIDO=Sistema
