    <element xsi:type="archimate:ApplicationService" id="svc-sos" name="SOS Service"/>
    <element xsi:type="archimate:ApplicationService" id="svc-notes" name="Notes Service&#xA;(notas clínicas privadas)"/>
    <element xsi:type="archimate:ApplicationService" id="svc-access" name="Access Log Middleware"/>
    <element xsi:type="archimate:ApplicationService" id="svc-scheduler" name="Scheduler&#xA;(APScheduler)"/>
